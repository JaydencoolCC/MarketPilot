generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Market {
  US
  HK
  CN
}

model WatchlistItem {
  id               String          @id @default(cuid())
  symbol           String
  normalizedSymbol String          @unique
  market           Market
  name             String
  currency         String
  costPrice        Decimal?        @db.Decimal(18, 6)
  shares           Decimal?        @db.Decimal(18, 6)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  quoteSnapshots   QuoteSnapshot[]
}

model FundWatchlistItem {
  id               String         @id @default(cuid())
  code             String
  normalizedSymbol String         @unique
  type             String
  market           Market?
  name             String
  currency         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  snapshots        FundSnapshot[]
}

model FundSnapshot {
  id              String            @id @default(cuid())
  fundItemId      String
  fundItem        FundWatchlistItem @relation(fields: [fundItemId], references: [id], onDelete: Cascade)
  symbol          String            @unique
  netValue        Decimal           @db.Decimal(18, 6)
  estimateValue   Decimal?          @db.Decimal(18, 6)
  changePercent   Decimal           @db.Decimal(12, 6)
  currency        String
  provider        String
  quoteTime       DateTime
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime          @default(now())
}

model QuoteSnapshot {
  id              String        @id @default(cuid())
  watchlistItemId String
  watchlistItem   WatchlistItem @relation(fields: [watchlistItemId], references: [id], onDelete: Cascade)
  symbol          String        @unique
  price           Decimal       @db.Decimal(18, 6)
  change          Decimal       @db.Decimal(18, 6)
  changePercent   Decimal       @db.Decimal(12, 6)
  currency        String
  marketStatus    String
  provider        String
  quoteTime       DateTime
  errorCode       String?
  errorMessage    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
